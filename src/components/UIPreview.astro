---
---

<section id="preview" class="relative py-32 px-6 overflow-hidden">

  <!-- Background accent -->
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[500px] rounded-full"
         style="background:radial-gradient(ellipse,rgba(255,70,85,0.06),transparent 70%);filter:blur(80px)"></div>
  </div>

  <div class="max-w-6xl mx-auto">

    <!-- Section header -->
    <div class="text-center mb-16" data-reveal>
      <span class="section-label mb-4 inline-flex">Preview</span>
      <h2 class="text-4xl md:text-5xl font-black tracking-tighter text-white mb-4 leading-tight">
        Clean by design.<br/>
        <span class="text-gradient-red">Built for clarity.</span>
      </h2>
      <p class="max-w-md mx-auto text-base leading-relaxed" style="color:rgba(240,240,245,0.4)">
        Every pixel earns its place. No bloat, no noise —
        just the data you need when you need it.
      </p>
    </div>

    <!-- App window mock -->
    <div
      class="relative rounded-2xl overflow-hidden shadow-2xl"
      style="background:#0d0d18;border:1px solid rgba(255,255,255,0.08);box-shadow:0 0 0 1px rgba(255,255,255,0.04),0 40px 80px rgba(0,0,0,0.6),0 0 80px rgba(255,70,85,0.06)"
      data-reveal
      data-reveal-d="1"
    >
      <!-- Window chrome -->
      <div class="flex items-center gap-2 px-4 py-3 border-b" style="background:#0a0a14;border-color:rgba(255,255,255,0.06)">
        <div class="flex gap-1.5">
          <div class="w-3 h-3 rounded-full" style="background:#ff5f57"></div>
          <div class="w-3 h-3 rounded-full" style="background:#febc2e"></div>
          <div class="w-3 h-3 rounded-full" style="background:#28c840"></div>
        </div>
        <div class="flex-1 flex justify-center">
          <div class="flex items-center gap-2 px-4 py-1 rounded-md text-xs" style="background:rgba(255,255,255,0.04);color:rgba(240,240,245,0.3)">
            <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M5 8 L16 24 L27 8" stroke="#ff4655" stroke-width="4" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Vanta — koelss#000
          </div>
        </div>
        <div class="w-16"></div>
      </div>

      <!-- App body -->
      <div class="flex" style="min-height:480px">

        <!-- Sidebar -->
        <div class="flex flex-col gap-1 p-3 shrink-0" style="width:52px;background:#08080e;border-right:1px solid rgba(255,255,255,0.05)">
          <!-- Logo -->
          <div class="w-9 h-9 rounded-lg flex items-center justify-center mb-3 mx-auto" style="background:rgba(255,70,85,0.15)">
            <svg width="14" height="14" viewBox="0 0 32 32" fill="none">
              <path d="M5 8 L16 24 L27 8" stroke="#ff4655" stroke-width="4" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <!-- Nav icons -->
          {[
            `<path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>`,
            `<polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/>`,
            `<rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>`,
            `<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/>`,
          ].map((d, i) => (
            <div class="w-9 h-9 rounded-lg flex items-center justify-center mx-auto"
                 style={i === 0 ? "background:rgba(255,70,85,0.12);color:#ff6070" : "color:rgba(255,255,255,0.2)"}>
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <Fragment set:html={d} />
              </svg>
            </div>
          ))}
        </div>

        <!-- Main content -->
        <div class="flex-1 p-5 flex flex-col gap-4 overflow-hidden">

          <!-- Top row: Rank card + Live match -->
          <div class="grid grid-cols-3 gap-4">

            <!-- Rank card -->
            <div class="rounded-xl p-4 col-span-1" style="background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.06)">
              <div class="text-[0.55rem] font-mono tracking-widest uppercase mb-3" style="color:rgba(240,240,245,0.3)">Current Rank</div>
              <!-- Rank icon placeholder -->
              <div class="flex items-center gap-3 mb-3">
                <div class="w-12 h-12 rounded-lg flex items-center justify-center shrink-0" style="background:linear-gradient(135deg,rgba(255,70,85,0.2),rgba(255,140,90,0.1));border:1px solid rgba(255,70,85,0.2)">
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#ff6070" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
                  </svg>
                </div>
                <div>
                  <div class="text-white font-bold text-sm leading-none mb-1">Diamond 2</div>
                  <div class="flex items-center gap-1">
                    <div class="h-1 w-16 rounded-full overflow-hidden" style="background:rgba(255,255,255,0.08)">
                      <div class="h-full rounded-full w-[62%]" style="background:linear-gradient(90deg,#ff4655,#ff8a8a)"></div>
                    </div>
                    <span class="text-[0.55rem] font-mono" style="color:rgba(240,240,245,0.35)">62 RR</span>
                  </div>
                </div>
              </div>
              <!-- RR change pills -->
              <div class="flex gap-1.5">
                <span class="text-[0.6rem] font-mono px-1.5 py-0.5 rounded" style="background:rgba(52,199,89,0.1);color:#34c759">+20</span>
                <span class="text-[0.6rem] font-mono px-1.5 py-0.5 rounded" style="background:rgba(52,199,89,0.1);color:#34c759">+17</span>
                <span class="text-[0.6rem] font-mono px-1.5 py-0.5 rounded" style="background:rgba(255,70,85,0.1);color:#ff6070">-12</span>
                <span class="text-[0.6rem] font-mono px-1.5 py-0.5 rounded" style="background:rgba(52,199,89,0.1);color:#34c759">+23</span>
              </div>
            </div>

            <!-- Stats summary -->
            <div class="rounded-xl p-4 col-span-2" style="background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.06)">
              <div class="text-[0.55rem] font-mono tracking-widest uppercase mb-3" style="color:rgba(240,240,245,0.3)">This Session</div>
              <div class="grid grid-cols-4 gap-3">
                {[
                  { label: 'K/D', value: '1.42', up: true },
                  { label: 'ACS', value: '248', up: true },
                  { label: 'HS%', value: '31%', up: false },
                  { label: 'Win%', value: '67%', up: true },
                ].map(s => (
                  <div>
                    <div class="text-white font-bold text-lg leading-none mb-1">{s.value}</div>
                    <div class="text-[0.55rem] font-mono tracking-wide uppercase" style="color:rgba(240,240,245,0.3)">{s.label}</div>
                    <div class="mt-1.5 text-[0.55rem] font-mono" style={s.up ? "color:#34c759" : "color:#ff6070"}>
                      {s.up ? '▲' : '▼'} vs avg
                    </div>
                  </div>
                ))}
              </div>
              <!-- Mini bar chart -->
              <div class="mt-4 flex items-end gap-1" style="height:32px">
                {[45,60,38,72,55,80,65,70,48,82,60,74].map((h) => (
                  <div class="flex-1 rounded-sm" style={`height:${h}%;background:rgba(255,70,85,${0.15 + (h/100)*0.35})`}></div>
                ))}
              </div>
              <div class="text-[0.5rem] font-mono mt-1" style="color:rgba(240,240,245,0.2)">ACS last 12 matches</div>
            </div>
          </div>

          <!-- Bottom row: Match history + Rank graph -->
          <div class="grid grid-cols-5 gap-4 flex-1">

            <!-- Match history -->
            <div class="rounded-xl p-4 col-span-2 flex flex-col" style="background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.06)">
              <div class="text-[0.55rem] font-mono tracking-widest uppercase mb-3" style="color:rgba(240,240,245,0.3)">Recent Matches</div>
              <div class="flex flex-col gap-2 flex-1">
                {[
                  { map: 'Ascent',  agent: 'Jett',   result: 'W', score: '13–7',  rr: '+20', acs: 312 },
                  { map: 'Bind',    agent: 'Raze',   result: 'W', score: '13–9',  rr: '+17', acs: 271 },
                  { map: 'Haven',   agent: 'Jett',   result: 'L', score: '9–13',  rr: '−12', acs: 198 },
                  { map: 'Lotus',   agent: 'Neon',   result: 'W', score: '13–5',  rr: '+23', acs: 289 },
                  { map: 'Pearl',   agent: 'Jett',   result: 'L', score: '11–13', rr: '−8',  acs: 221 },
                ].map(m => (
                  <div class="flex items-center gap-2 py-1.5 border-b" style="border-color:rgba(255,255,255,0.04)">
                    <!-- Result -->
                    <div class="w-5 h-5 rounded flex items-center justify-center text-[0.5rem] font-bold shrink-0"
                         style={m.result === 'W' ? "background:rgba(52,199,89,0.12);color:#34c759" : "background:rgba(255,70,85,0.12);color:#ff6070"}>
                      {m.result}
                    </div>
                    <!-- Map + agent -->
                    <div class="flex-1 min-w-0">
                      <div class="text-[0.6rem] font-medium text-white truncate">{m.map}</div>
                      <div class="text-[0.5rem] font-mono" style="color:rgba(240,240,245,0.3)">{m.agent} · {m.score}</div>
                    </div>
                    <!-- ACS -->
                    <div class="text-[0.55rem] font-mono text-right shrink-0" style="color:rgba(240,240,245,0.4)">{m.acs}</div>
                    <!-- RR -->
                    <div class="text-[0.55rem] font-mono text-right w-8 shrink-0"
                         style={m.result === 'W' ? "color:#34c759" : "color:#ff6070"}>
                      {m.rr}
                    </div>
                  </div>
                ))}
              </div>
            </div>

            <!-- Rank progression graph -->
            <div class="rounded-xl p-4 col-span-3 flex flex-col" style="background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.06)">
              <div class="flex items-center justify-between mb-3">
                <div class="text-[0.55rem] font-mono tracking-widest uppercase" style="color:rgba(240,240,245,0.3)">RR Progression</div>
                <div class="flex gap-1">
                  {['1D','7D','30D'].map((t, i) => (
                    <span class="text-[0.5rem] font-mono px-1.5 py-0.5 rounded"
                          style={i === 1 ? "background:rgba(255,70,85,0.15);color:#ff6070" : "color:rgba(240,240,245,0.25)"}>
                      {t}
                    </span>
                  ))}
                </div>
              </div>

              <!-- SVG line chart -->
              <div class="flex-1 relative">
                <svg viewBox="0 0 300 140" class="w-full h-full" preserveAspectRatio="none">
                  <!-- Grid lines -->
                  <line x1="0" y1="35" x2="300" y2="35" stroke="rgba(255,255,255,0.05)" stroke-width="1"/>
                  <line x1="0" y1="70" x2="300" y2="70" stroke="rgba(255,255,255,0.05)" stroke-width="1"/>
                  <line x1="0" y1="105" x2="300" y2="105" stroke="rgba(255,255,255,0.05)" stroke-width="1"/>
                  <!-- Area fill -->
                  <path d="M0,110 L25,95 L50,100 L75,80 L100,85 L125,65 L150,70 L175,50 L200,55 L225,35 L250,40 L275,20 L300,25 L300,140 L0,140 Z"
                        fill="url(#areaGrad)" opacity="0.4"/>
                  <!-- Line -->
                  <path d="M0,110 L25,95 L50,100 L75,80 L100,85 L125,65 L150,70 L175,50 L200,55 L225,35 L250,40 L275,20 L300,25"
                        fill="none" stroke="#ff4655" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                  <!-- Dots -->
                  {[[0,110],[75,80],[150,70],[225,35],[300,25]].map(([x,y]) => (
                    <circle cx={x} cy={y} r="3" fill="#ff4655" stroke="#0d0d18" stroke-width="2"/>
                  ))}
                  <defs>
                    <linearGradient id="areaGrad" x1="0" y1="0" x2="0" y2="1">
                      <stop offset="0%" stop-color="#ff4655" stop-opacity="0.4"/>
                      <stop offset="100%" stop-color="#ff4655" stop-opacity="0"/>
                    </linearGradient>
                  </defs>
                </svg>
                <!-- Y axis labels -->
                <div class="absolute left-0 top-0 h-full flex flex-col justify-between pointer-events-none pb-1">
                  {['100 RR','75 RR','50 RR','25 RR'].map(l => (
                    <span class="text-[0.45rem] font-mono" style="color:rgba(240,240,245,0.2)">{l}</span>
                  ))}
                </div>
              </div>

              <!-- Bottom stat pills -->
              <div class="flex gap-3 mt-3 pt-3 border-t" style="border-color:rgba(255,255,255,0.05)">
                <div>
                  <div class="text-[0.5rem] font-mono" style="color:rgba(240,240,245,0.3)">Peak RR</div>
                  <div class="text-xs font-semibold text-white">94 RR</div>
                </div>
                <div>
                  <div class="text-[0.5rem] font-mono" style="color:rgba(240,240,245,0.3)">Net 7d</div>
                  <div class="text-xs font-semibold" style="color:#34c759">+63 RR</div>
                </div>
                <div>
                  <div class="text-[0.5rem] font-mono" style="color:rgba(240,240,245,0.3)">Streak</div>
                  <div class="text-xs font-semibold" style="color:#34c759">W3</div>
                </div>
              </div>
            </div>

          </div>
        </div>
      </div>
    </div>

    <!-- Caption below -->
    <p class="text-center mt-6 text-sm" style="color:rgba(240,240,245,0.25)" data-reveal data-reveal-d="2">
      Static UI mockup — actual app interface may vary slightly.
    </p>
  </div>
</section>
